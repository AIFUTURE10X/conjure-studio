# v0 Prompts Genie — environment variables
# Copy to .env.local for development. In production, set these in
# Vercel → Settings → Environment Variables (all environments).

# ── Database (required) ────────────────────────────────────────────────
# Neon PostgreSQL connection string (history, favorites, logo history)
NEON_DATABASE_URL=
# Legacy alias used by the image-analysis routes; set to the same value
DATABASE_URL=

# ── AI generation (OpenAI primary, Gemini optional fallback) ────────────
# OpenAI (primary reliability path: ChatGPT Images, AI helper, analyze-image,
# prompt enhancement, logo generation, recolor)
OPENAI_API_KEY=

# Google Gemini (optional image-generation fallback/model picker paths)
GOOGLE_AI_API_KEY=
# Alias also accepted by the Gemini client
# GEMINI_API_KEY=

# ── Background removal + video generation ───────────────────────────────
# fal.ai — pay-as-you-go, no subscription. REQUIRED for video generation
# (Seedance/Kling/Veo via the fal queue) and the BG Remover's default
# method (BiRefNet v2 — falls back to PhotoRoom without it).
# Key from https://fal.ai/dashboard/keys
FAL_KEY=

# PhotoRoom — professional PNG background removal (logo flows + fallback)
PHOTOROOM_API_KEY=
# PIXELCUT_API_KEY=
# REMOVE_BG_API_KEY=

# ── Other providers ─────────────────────────────────────────────────────
# Replicate (upscaling fallback paths)
REPLICATE_API_TOKEN=

# ── Storage ──────────────────────────────────────────────────────────────
# Vercel Blob read-write token (history/favorites image persistence).
# Auto-provisioned on Vercel; needed locally to test persistence.
BLOB_READ_WRITE_TOKEN=

# ── Auth (required for accounts) ─────────────────────────────────────────
# Better Auth signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BETTER_AUTH_SECRET=
# Canonical app URL for auth callbacks. REQUIRED when the app is served from
# a custom domain (Vercel infers the *.vercel.app URL otherwise, which breaks
# sign-in on the real domain).
# BETTER_AUTH_URL=https://conjure.aifuturestudio.com
# Extra origins allowed to call the auth endpoints (comma-separated), e.g.
# when old and new domains are both live during a migration.
# BETTER_AUTH_TRUSTED_ORIGINS=https://v0promptsgenie.vercel.app

# Google sign-in (optional — the button appears automatically when set).
# Create OAuth credentials at console.cloud.google.com; authorized redirect:
#   https://YOUR_DOMAIN/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Billing (required to sell credits) ───────────────────────────────────
# Stripe secret key (dashboard.stripe.com → Developers → API keys)
STRIPE_SECRET_KEY=
# Webhook signing secret for endpoint POST /api/stripe/webhook
# (subscribe to checkout.session.completed)
STRIPE_WEBHOOK_SECRET=

# ── SaaS enforcement (the go-live switch) ────────────────────────────────
# off (default): app works exactly as before — anonymous, uncharged.
# on: generation routes require sign-in and debit credits.
# Flip to "on" only after Stripe + auth env vars are set in production.
SAAS_ENFORCEMENT=off

# ── Rate limiting (recommended in production) ────────────────────────────
# Upstash Redis REST credentials — shared sliding-window limits across
# instances (per-user when signed in, per-IP otherwise). Without these, a
# weaker in-memory limiter still applies.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Admin / ops (optional) ───────────────────────────────────────────────
# Gates POST/GET /api/logo-history/debug (account merge tooling).
# Leave unset to keep the endpoint closed.
# ADMIN_API_KEY=

# ── OpenAI retry/model tuning (optional, sensible defaults in code) ─────
# OPENAI_TEXT_MODEL=
# OPENAI_TEXT_MAX_ATTEMPTS=
# OPENAI_TEXT_RETRY_BASE_DELAY=

# ── Gemini retry tuning (optional fallback paths only) ──────────────────
# GEMINI_MAX_ATTEMPTS=
# GEMINI_RETRY_BASE_DELAY=
# GEMINI_OVERLOAD_BASE_DELAY=
# GEMINI_MAX_BACKOFF=
